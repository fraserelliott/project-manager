<Window x:Class="ProjectBoard.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Project Board" Height="500" Width="700"
        ResizeMode="CanMinimize" Background="{StaticResource AppBackground}" Foreground="{StaticResource TextPrimary}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Menu>
            <MenuItem Header="_File" />
            <MenuItem Header="_Edit" />
        </Menu>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="20">
            <Image Source="Assets/Images/Logo.png" Width="80" Height="80" Margin="0,0,8,0" VerticalAlignment="Center" />
            <TextBlock Text="Project Board" FontSize="40" VerticalAlignment="Center" />
        </StackPanel>

        <Grid Grid.Row="2" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0, 0, 16, 0" Style="{StaticResource PanelBorder}"
                    Visibility="{Binding HasRecentProjects, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Search Recent Projects" Style="{StaticResource VerticalFieldLabel}" />

                    <Grid Grid.Row="1">
                        <TextBox Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center" Style="{StaticResource FieldTextBox}" Padding="6,2,22,2" />
                        <Button Content="&#xE711;" Style="{StaticResource PrimaryIconButton}" Margin="0,0,4,0"
                                Command="{Binding ClearSearchCommand}" Width="16" Height="16" MinHeight="16"
                                FontSize="10" HorizontalAlignment="Right"
                                Visibility="{Binding SearchText, Converter={StaticResource StringNotEmptyToVisibilityConverter}}" />
                    </Grid>


                    <ListView Grid.Row="2" ItemsSource="{Binding RecentProjectsView}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border MouseLeftButtonDown="RecentProject_DoubleClick">
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Open" Click="OpenRecentProject_Click" />
                                            <MenuItem Header="Remove" Click="RemoveRecentProject_Click" />
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <StackPanel Margin="0,6">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />

                                        <TextBlock Text="{Binding FilePath}" Margin="0,2,0,0"
                                                   Foreground="{StaticResource TextMuted}"
                                                   TextTrimming="CharacterEllipsis" Opacity="0.8" />

                                        <TextBlock Text="{Binding LastOpenedString}" Margin="0,2,0,0" Opacity="0.65"
                                                   FontSize="11" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="0" Margin="0, 0, 16, 0" Style="{StaticResource PanelBorder}"
                    Visibility="{Binding HasRecentProjects, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <TextBlock Grid.Row="2" FontSize="16" TextWrapping="Wrap">
                    <Run FontWeight="Bold">No recent projects</Run><LineBreak /><LineBreak />
                    Create a new project or open an existing one.<LineBreak />
                    You can also clone the demo project to explore the features.
                </TextBlock>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelBorder}">
                <StackPanel>
                    <TextBlock Style="{StaticResource VerticalFieldLabel}" Text="Get Started" />
                    <Button Style="{StaticResource PrimaryButton}" Margin="0,0,0,8"
                            Command="{Binding NewProjectCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE8F4;" />
                            <TextBlock Text=" New Project" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource PrimaryButton}" Margin="0,0,0,8"
                            Command="{Binding LoadProjectCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE838;" />
                            <TextBlock Text=" Open Project" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource PrimaryButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE8C8;" />
                            <TextBlock Text=" Clone Demo Project" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>