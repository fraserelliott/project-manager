<UserControl x:Class="ProjectBoard.Controls.TitleBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" mc:Ignorable="d" d:DesignHeight="40"
             d:DesignWidth="300" WindowChrome.IsHitTestVisibleInChrome="True">
    <Border Background="{StaticResource AppBackground}" BorderThickness="0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Drag area -->
            <Border Grid.Column="0" Background="Transparent" MouseLeftButtonDown="DragArea_MouseLeftButtonDown">
                <DockPanel LastChildFill="True" Margin="10,0,0,0">
                    <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Title}"
                               VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="White" />
                </DockPanel>
            </Border>

            <!-- Window buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="&#xE921;" FontFamily="Segoe MDL2 Assets" Width="46" Height="36"
                        Style="{StaticResource TitleBarButtonStyle}"
                        Visibility="{Binding ShowMinimize, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"
                        Click="Minimise_Click" />

                <Button Content="&#xE922;" FontFamily="Segoe MDL2 Assets" Width="46" Height="36"
                        Style="{StaticResource TitleBarButtonStyle}"
                        Visibility="{Binding ShowMaximize, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"
                        Click="Maximise_Click" />

                <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" Width="46" Height="36"
                        Style="{StaticResource TitleBarExitButtonStyle}" Click="Close_Click" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>