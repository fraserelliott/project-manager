<Window x:Class="ProjectBoard.Views.TaskDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:ProjectBoard.Controls" mc:Ignorable="d" Title="TaskDetailsWindow" Height="600"
        Width="800" Background="{StaticResource AppBackground}" Foreground="{StaticResource TextPrimary}">
    <Border Padding="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Style="{StaticResource FieldContainer}">
                    <TextBlock Style="{StaticResource VerticalFieldLabel}" Text="ID" />
                    <TextBlock Text="{Binding Id}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Style="{StaticResource FieldContainer}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource VerticalFieldLabel}" Text="Name" />
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE946;" Margin="4,0,0,0"
                                   VerticalAlignment="Center" ToolTip="Task names must be unique within the project." />
                    </StackPanel>
                    <TextBox Text="{Binding FormName}" KeyDown="TextBox_KeyDown" IsReadOnly="{Binding IsNotEditing}"
                             MinWidth="200" Style="{StaticResource FieldTextBoxWithError}" Tag="{Binding HasNameError}" />
                    <Grid Visibility="{Binding HasNameError, Converter={StaticResource BoolToVisibilityConverter}}"
                          Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{Binding NameErrorMessage}"
                                   Foreground="{StaticResource BtnDanger}" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Margin="8,0,0,0" ToolTip="Restore original name"
                                Command="{Binding RestoreNameCommand}" Style="{StaticResource PrimaryIconButton}">
                            <TextBlock Text="&#xE7A7;" />
                        </Button>
                    </Grid>
                </StackPanel>
                <StackPanel Grid.Column="2" Style="{StaticResource FieldContainer}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource VerticalFieldLabel}" Text="Priority" />
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE946;" Margin="4,0,0,0"
                                   VerticalAlignment="Center" ToolTip="Priority accepts any integer value." />
                    </StackPanel>
                    <TextBox Text="{Binding FormPriority}" KeyDown="TextBox_KeyDown"
                             IsReadOnly="{Binding IsNotEditing}" Style="{StaticResource FieldTextBoxWithError}"
                             Tag="{Binding HasPriorityError}" />
                    <Button Grid.Column="1" Margin="8,4,0,0" ToolTip="Restore original priority"
                            Command="{Binding RestorePriorityCommand}" Style="{StaticResource PrimaryIconButton}"
                            Visibility="{Binding HasPriorityError, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="&#xE7A7;" />
                    </Button>
                </StackPanel>
                <StackPanel Grid.Column="3" Style="{StaticResource FieldContainer}">
                    <ToggleButton IsChecked="{Binding IsEditing, Mode=TwoWay}"
                                  Style="{StaticResource EditToggleButton}" Margin="0,0,0,8" />
                    <Button Content="{Binding ButtonText}" Command="{Binding AdvanceStatusCommand}"
                            CommandParameter="{Binding Id}" Style="{StaticResource PrimaryButton}" />
                </StackPanel>
            </Grid>

            <!-- tags-->
            <Grid Grid.Row="1" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Style="{StaticResource HorizontalFieldLabel}" Text="Tags" />
                <controls:TagsDisplay Grid.Column="1" Tags="{Binding Tags}" ShowRemoveButton="{Binding IsEditing}"
                                      UpdateTagCommand="{Binding UpdateTagCommand}"
                                      RemoveTagCommand="{Binding RemoveTagCommand}"
                                      DeleteTagCommand="{Binding DeleteTagCommand}" />
                <TextBlock Grid.Column="2" Style="{StaticResource HorizontalFieldLabel}" Text="Add Tag" />
                <controls:SearchPicker Grid.Column="3" ItemsSource="{Binding AvailableTagOptions}"
                                       SearchText="{Binding TagSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       ItemChosenHandler="{Binding TagOptionChosenHandler}"
                                       IsEnabled="{Binding IsEditing }" />
            </Grid>

            <!-- description label -->
            <TextBlock Grid.Row="2" Style="{StaticResource VerticalFieldLabel}" Text="Description" />

            <!-- description -->
            <controls:MarkdownView Grid.Row="3" Text="{Binding Description, Mode=TwoWay}"
                                   ViewMode="{Binding MarkdownViewMode}" />

            <!-- dependencies-->
            <Grid Grid.Row="4" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Style="{StaticResource HorizontalFieldLabel}" Text="Dependencies" />
                <controls:DependenciesDisplay Grid.Column="1" Dependencies="{Binding Dependencies}"
                                              ShowRemoveButton="{Binding IsEditing}"
                                              RemoveDependencyCommand="{Binding RemoveDependencyCommand}" />
                <TextBlock Grid.Column="2" Style="{StaticResource HorizontalFieldLabel}" Text="Add Dependency" />
                <controls:SearchPicker Grid.Column="3" ItemsSource="{Binding AvailableDependencies}"
                                       SearchText="{Binding DependencySearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       Visibility="{Binding HasAvailableDependencies, Converter={StaticResource BoolToVisibilityConverter}}"
                                       ItemChosenHandler="{Binding DependencyOptionChosenHandler}"
                                       IsEnabled="{Binding IsEditing }" />
                <TextBlock Grid.Column="3"
                           Visibility="{Binding HasAvailableDependencies, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <Run Text="None Available" />
                    <Run FontFamily="Segoe MDL2 Assets" Text="&#xE946;"
                         ToolTip="All valid dependency options have already been used, or would create a cycle." />
                </TextBlock>
            </Grid>

            <!-- delete button -->
            <Button Grid.Row="5" Margin="0,8,0,0" HorizontalAlignment="Right" Content="Delete"
                    Command="{Binding ConfirmDeleteTask}" Style="{StaticResource DangerButton}" />
        </Grid>
    </Border>
</Window>