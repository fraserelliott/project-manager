<UserControl x:Class="ProjectBoard.Windows.TasksView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:ProjectBoard.Controls" mc:Ignorable="d" d:DesignHeight="450"
             d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="TaskRowStyleWithDoubleClick" TargetType="DataGridRow"
               BasedOn="{StaticResource TaskDataGridRowStyle}">

            <EventSetter Event="MouseDoubleClick" Handler="DataGridRow_MouseDoubleClick" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="New Task" Style="{StaticResource PrimaryButton}"
                    Command="{Binding NewTaskCommand}" HorizontalAlignment="Left" />

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                <ToggleButton Content="&#xE930;" IsChecked="{Binding Filters.HideCompleted, Mode=TwoWay}"
                              ToolTip="Hide completed tasks" FontFamily="Segoe MDL2 Assets" MinWidth="35"
                              MinHeight="30" Style="{StaticResource EditToggleButton}" Margin="0,0,8,0" />
                <ToggleButton Content="&#xE72E;" IsChecked="{Binding Filters.HideBlocked, Mode=TwoWay}"
                              ToolTip="Hide blocked tasks" FontFamily="Segoe MDL2 Assets" MinWidth="35" MinHeight="30"
                              Style="{StaticResource EditToggleButton}" Margin="0,0,8,0" />
                <ToggleButton Content="&#xE7BA;" IsChecked="{Binding Filters.HideStale, Mode=TwoWay}"
                              ToolTip="Hide stale tasks" FontFamily="Segoe MDL2 Assets" MinWidth="35" MinHeight="30"
                              Style="{StaticResource EditToggleButton}" Margin="0,0,0,0" />
                <Border Width="2" Height="18" Margin="6,0" Background="{StaticResource BtnPrimaryHover}"
                        VerticalAlignment="Center" HorizontalAlignment="Center" />
                <Button Content="&#xE894;" Command="{Binding ResetFiltersCommand}" ToolTip="Reset filters"
                        MinHeight="30" FontFamily="Segoe MDL2 Assets" Width="35" Style="{StaticResource PrimaryButton}" />
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="1" FontSize="16" TextWrapping="Wrap"
                   Visibility="{Binding HasTasks, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                   Foreground="{StaticResource TextPrimary}">
            <Run FontWeight="Bold">No tasks</Run><LineBreak /><LineBreak />
            Add your first task to get started.
        </TextBlock>

        <DataGrid Grid.Row="1" ItemsSource="{Binding TasksCollectionView}"
                  SelectedItem="{Binding SelectedTask, Mode=TwoWay}" SelectionMode="Single" SelectionUnit="FullRow"
                  EnableRowVirtualization="True" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                  Background="{StaticResource BgPrimary}" Foreground="{StaticResource TextPrimary}"
                  GridLinesVisibility="None" HeadersVisibility="Column"
                  RowStyle="{StaticResource TaskRowStyleWithDoubleClick}"
                  Visibility="{Binding HasTasks, Converter={StaticResource BoolToVisibilityConverter}}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" />
                <DataGridTemplateColumn Header="Tags">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <controls:TagsDisplay Tags="{Binding Tags}" UpdateTagCommand="{Binding UpdateTagCommand}"
                                                  RemoveTagCommand="{Binding RemoveTagCommand}"
                                                  DeleteTagCommand="{Binding DeleteTagCommand}"
                                                  VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"
                                    ElementStyle="{StaticResource GridTextStyle}" />
                <DataGridTemplateColumn Header="Alerts" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <StackPanel.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="Margin" Value="0,0,8,0" />
                                    </Style>
                                </StackPanel.Resources>

                                <!-- Blocked -->
                                <Border Style="{StaticResource AlertPill}" Tag="{Binding IsBlocked}"
                                        Background="{StaticResource BtnDanger}">
                                    <TextBlock Style="{StaticResource PillText}">
                                        <Run FontFamily="Segoe MDL2 Assets" Text="&#xE72E;" />
                                        <Run Text="  Blocked" />
                                    </TextBlock>
                                </Border>

                                <!-- Stale -->
                                <Border Style="{StaticResource AlertPill}" Tag="{Binding IsStale}" Background="#F59E0B">
                                    <TextBlock Style="{StaticResource PillText}">
                                        <Run FontFamily="Segoe MDL2 Assets" Text="&#xE7BA;" />
                                        <Run Text="  Stale" />
                                    </TextBlock>
                                </Border>

                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Actions">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding ButtonText}" Command="{Binding AdvanceStatusCommand}"
                                    CommandParameter="{Binding Id}" Style="{StaticResource PrimaryButtonCompact}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Priority" Binding="{Binding Priority}" Width="*"
                                    ElementStyle="{StaticResource GridTextStyle}" />
                <DataGridTemplateColumn Header="Details">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Details"
                                    Command="{Binding DataContext.ShowDetailsCommand,RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding Id}" Style="{StaticResource PrimaryButtonCompact}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>

</UserControl>