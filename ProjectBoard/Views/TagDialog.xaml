<Window x:Class="ProjectBoard.Views.TagDialog" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="{Binding Title}" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="ToolWindow" ShowInTaskbar="False"
        Icon="{x:Null}" Background="{StaticResource AppBackground}" Foreground="{StaticResource TextPrimary}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Tag name" Style="{StaticResource VerticalFieldLabel}" />

        <TextBox Grid.Row="1" MinWidth="320" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                 x:Name="ValueTextBox" Margin="0,0,0,12" Style="{StaticResource FieldTextBox}" />

        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="{StaticResource BtnDanger}"
                   TextWrapping="Wrap" Margin="0,0,0,12" />

        <TextBlock Grid.Row="3" Text="Color" Style="{StaticResource VerticalFieldLabel}" />

        <ListBox Grid.Row="4" ItemsSource="{Binding AvailableColors}" SelectedItem="{Binding SelectedColorOption}"
                 Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Center"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Disabled" SelectionMode="Single" Margin="0,0,0,12">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel HorizontalAlignment="Center" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="Margin" Value="4,0,4,0" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="SelectionBorder" Padding="2" Background="Transparent"
                                        BorderBrush="Transparent" BorderThickness="2" CornerRadius="6"
                                        SnapsToDevicePixels="True">
                                    <ContentPresenter />
                                </Border>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="SelectionBorder" Property="BorderBrush"
                                                Value="{StaticResource BrushBorderSubtle}" />
                                    </Trigger>

                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="SelectionBorder" Property="BorderBrush"
                                                Value="{StaticResource BrushAccent}" />
                                    </Trigger>

                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsSelected" Value="True" />
                                            <Condition Property="IsMouseOver" Value="True" />
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="SelectionBorder" Property="BorderBrush"
                                                Value="{StaticResource BrushAccent}" />
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Width="24" Height="24" ToolTip="{Binding Name}">
                        <Border x:Name="SwatchBorder" Background="{Binding SwatchBrush}"
                                BorderBrush="{StaticResource BrushBorderSubtle}" BorderThickness="1" CornerRadius="4" />
                        <Path x:Name="NoneGlyph" Data="M 5,19 L 19,5" Stroke="{StaticResource TextMuted}"
                              StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Visibility="Collapsed" />
                    </Grid>

                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsNone}" Value="True">
                            <Setter TargetName="SwatchBorder" Property="Background" Value="Transparent" />
                            <Setter TargetName="NoneGlyph" Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Cancel" MinWidth="90" Margin="0,0,8,0" IsCancel="True"
                    Style="{StaticResource PrimaryButton}" />
            <Button Content="{Binding SubmitText}" MinWidth="90" IsDefault="True" IsEnabled="{Binding CanSubmit}"
                    Command="{Binding SubmitCommand}" Style="{StaticResource PrimaryButton}" />
        </StackPanel>
    </Grid>
</Window>