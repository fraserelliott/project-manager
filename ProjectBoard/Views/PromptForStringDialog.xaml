<Window x:Class="ProjectBoard.Views.PromptForStringDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="{Binding Title}" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="ToolWindow" ShowInTaskbar="False"
        Icon="{x:Null}" Background="{StaticResource AppBackground}" Foreground="{StaticResource TextPrimary}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Label}" Margin="0,0,0,6" />

        <TextBox Grid.Row="1" MinWidth="320" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                 x:Name="ValueTextBox" Margin="0,0,0,12" Style="{StaticResource FieldTextBox}" />

        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="{StaticResource BtnDanger}"
                   TextWrapping="Wrap" Margin="0,0,0,12" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" MinWidth="90" Margin="0,0,8,0" IsCancel="True"
                    Style="{StaticResource PrimaryButton}" />
            <Button Content="{Binding SubmitText}" MinWidth="90" IsDefault="True" IsEnabled="{Binding CanSubmit}"
                    Command="{Binding SubmitCommand}" Style="{StaticResource PrimaryButton}" />
        </StackPanel>
    </Grid>
</Window>