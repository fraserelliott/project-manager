<Window x:Class="ProjectBoard.Views.ConfirmDialog" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d"
        SizeToContent="WidthAndHeight" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="None"
        BorderBrush="{StaticResource BrushBorderSubtle}" BorderThickness="3" ShowInTaskbar="False"
        Background="{StaticResource AppBackground}" Foreground="{StaticResource TextPrimary}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Label}" Margin="0,0,0,12" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Cancel" MinWidth="90" Margin="0,0,8,0" IsCancel="True"
                    Style="{StaticResource PrimaryButton}" />
            <Button Content="{Binding SubmitText}" MinWidth="90" IsDefault="True" Command="{Binding SubmitCommand}"
                    Style="{StaticResource PrimaryButton}" />
        </StackPanel>
    </Grid>
</Window>