<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="BgPrimary" Color="#0F172A"/>
    <SolidColorBrush x:Key="BgSecondary" Color="#1E293B"/>
    <SolidColorBrush x:Key="DropdownBg" Color="#334155"/>
    <SolidColorBrush x:Key="AppBackground" Color="#0F172A"/>
    <SolidColorBrush x:Key="SurfaceBackground" Color="#1E293B"/>
    <SolidColorBrush x:Key="BrushFieldReadOnlyBackground" Color="#1E293B"/>
    <SolidColorBrush x:Key="BrushBorderSubtle" Color="#334155"/>
    <SolidColorBrush x:Key="FocusedWithError" Color="#F87171"/>
    <SolidColorBrush x:Key="BrushAccent" Color="#3B82F6"/>

    <SolidColorBrush x:Key="BtnPrimary" Color="#64748B"/>
    <SolidColorBrush x:Key="BtnPrimaryHover" Color="#475569"/>
    <SolidColorBrush x:Key="BtnPrimaryActive" Color="#334155"/>
    <SolidColorBrush x:Key="BtnPrimaryDisabled" Color="#475569"/>
    
    <SolidColorBrush x:Key="BtnDanger" Color="#EF4444"/>
    <SolidColorBrush x:Key="BtnDangerHover" Color="#DC2626"/>
    <SolidColorBrush x:Key="BtnDangerActive" Color="#B91C1C"/>
    <SolidColorBrush x:Key="BtnDangerDisabled" Color="#7F1D1D"/>

    <SolidColorBrush x:Key="TextPrimary" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="TextMuted" Color="#94A3B8"/>

    <!-- Fonts -->
    <FontFamily x:Key="FontPrimary">Segoe UI</FontFamily>
</ResourceDictionary>