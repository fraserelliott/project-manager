<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2A3A55"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#2A3A55"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#F1F5F9"/>

    <Style x:Key="GridTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlock}">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="0,0,0,0"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="8,0"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>

        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#2A3A55"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            </Trigger>

            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#22314A"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="BaseDataGridRowStyle" TargetType="DataGridRow">
        <Setter Property="Background" Value="{StaticResource BgSecondary}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="MinHeight" Value="36"/>

        <Style.Triggers>

            <!-- Hover: tiny lift -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#22314A" />
            </Trigger>

            <!-- Selected: subtle, not neon -->
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#2A3A55" />
            </Trigger>

        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <!-- Base look -->
        <Setter Property="Background" Value="{StaticResource DropdownBg}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="BorderBrush" Value="#2A394F"/>

        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>

        <!-- Remove default ugly focus -->
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />

        <Style.Triggers>

            <!-- Hover -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BtnPrimaryHover}" />
            </Trigger>

            <!-- Pressed -->
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource BtnPrimaryActive}" />
            </Trigger>

        </Style.Triggers>
    </Style>

    <!-- Task-specific -->
    <Style x:Key="TaskDataGridRowStyle"
       TargetType="DataGridRow"
       BasedOn="{StaticResource BaseDataGridRowStyle}">
        <Style.Triggers>

            <!-- Completed tint -->
            <DataTrigger Binding="{Binding Status}" Value="Completed">
                <Setter Property="Background" Value="#1E2E26"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>