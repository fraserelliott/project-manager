<Window x:Class="ProjectManager.Views.ProjectWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vmtasks="clr-namespace:ProjectManager.ViewModels.Tasks"
        xmlns:vmnotes="clr-namespace:ProjectManager.ViewModels.Notes" xmlns:views="clr-namespace:ProjectManager.Views"
        mc:Ignorable="d" Title="ProjectManager" Height="600" Width="1000" Background="{StaticResource AppBackground}">
    <Window.Resources>

        <DataTemplate DataType="{x:Type vmtasks:TasksViewModel}">
            <views:TasksView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vmnotes:NotesViewModel}">
            <views:NotesView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- menu -->
            <RowDefinition Height="Auto" />
            <!-- tabs -->
            <RowDefinition Height="*" />
            <!-- content -->
        </Grid.RowDefinitions>

        <!-- Menu -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File" />
            <MenuItem Header="_Edit" />
        </Menu>

        <!-- Tabs (top-left) -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="12,10,12,0" HorizontalAlignment="Left">
            <!-- Tasks tab -->
            <Button Content="Tasks" Command="{Binding ShowTasksCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource TabButtonBaseStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTasksActive}" Value="True">
                                <Setter Property="Background" Value="{StaticResource BtnPrimary}" />
                                <Setter Property="BorderBrush" Value="{StaticResource BtnPrimary}" />
                                <Setter Property="BorderThickness" Value="1,1,1,0" />
                                <Setter Property="Margin" Value="0,0,6,-1" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsTasksActive}" Value="False">
                                <Setter Property="Margin" Value="0,0,6,0" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Notes tab -->
            <Button Content="Notes" Command="{Binding ShowNotesCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource TabButtonBaseStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsNotesActive}" Value="True">
                                <Setter Property="Background" Value="{StaticResource BtnPrimary}" />
                                <Setter Property="BorderBrush" Value="{StaticResource BtnPrimary}" />
                                <Setter Property="BorderThickness" Value="1,1,1,0" />
                                <Setter Property="Margin" Value="0,0,6,-1" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsNotesActive}" Value="False">
                                <Setter Property="Margin" Value="0,0,6,0" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- Content surface -->
        <Border Grid.Row="2" Margin="12,0,12,12" Padding="8" CornerRadius="6" BorderThickness="1"
                BorderBrush="{StaticResource BtnPrimary}" Background="{StaticResource SurfaceBackground}">
            <ContentControl Content="{Binding CurrentViewModel}" />
        </Border>
    </Grid>
</Window>