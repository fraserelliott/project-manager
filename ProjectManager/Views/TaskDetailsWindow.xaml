<Window x:Class="ProjectManager.Views.TaskDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjectManager.Views"
        mc:Ignorable="d"
        Title="TaskDetailsWindow" Height="600" Width="800"
        Background="{StaticResource AppBackground}"
        Foreground="{StaticResource TextPrimary}"
        >
    <Border Padding="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- header -->
                <RowDefinition Height="Auto"/>
                <!-- tags/status -->
                <RowDefinition Height="Auto"/>
                <!-- description label -->
                <RowDefinition Height="*"/>
                <!-- description (grows) -->
                <RowDefinition Height="Auto"/>
                <!-- deps/delete -->
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Style="{StaticResource FieldContainer}">
                    <TextBlock Style="{StaticResource VerticalFieldLabel}" Text="ID" />
                    <TextBlock Text="{Binding Id}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Style="{StaticResource FieldContainer}">
                    <TextBlock Style="{StaticResource VerticalFieldLabel}" Text="Name"/>
                    <TextBox Text="{Binding FormName}" KeyDown="TextBox_KeyDown" IsReadOnly="{Binding IsNotEditing}" MinWidth="200" Style="{StaticResource FieldTextBoxWithError}" Tag="{Binding HasNameError}" />
                    <Grid Visibility="{Binding HasNameError, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{Binding NameErrorMessage}" Foreground="{StaticResource BtnDanger}" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Margin="8,0,0,0" ToolTip="Restore original name" Command="{Binding RestoreNameCommand}" Style="{StaticResource PrimaryIconButton}">
                            <TextBlock Text="&#xE7A7;" />
                        </Button>
                    </Grid>
                </StackPanel>
                <StackPanel Grid.Column="2"  Style="{StaticResource FieldContainer}">
                    <TextBlock Style="{StaticResource VerticalFieldLabel}" Text="Priority"/>
                    <TextBox Text="{Binding FormPriority}" KeyDown="TextBox_KeyDown" IsReadOnly="{Binding IsNotEditing}" Style="{StaticResource FieldTextBoxWithError}" Tag="{Binding HasPriorityError}"/>
                    <Button Grid.Column="1" Margin="8,4,0,0" ToolTip="Restore original priority" Command="{Binding RestorePriorityCommand}" Style="{StaticResource PrimaryIconButton}" Visibility="{Binding HasPriorityError, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="&#xE7A7;" />
                    </Button>
                </StackPanel>
                <StackPanel Grid.Column="3" Style="{StaticResource FieldContainer}">
                    <ToggleButton IsChecked="{Binding IsEditing, Mode=TwoWay}" Style="{StaticResource EditToggleButton}" Margin="0,0,0,8"/>
                    <Button Content="{Binding ButtonText}" Command="{Binding AdvanceStatusCommand}" CommandParameter="{Binding Id}" Style="{StaticResource PrimaryButton}" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- TODO: tags control -->
                <TextBlock Grid.Column="0" Style="{StaticResource HorizontalFieldLabel}" Text="Tags"/>
                <TextBlock Grid.Column="1" Text="Placeholder for tags" />
            </Grid>

            <TextBlock Grid.Row="2" Style="{StaticResource VerticalFieldLabel}" Text="Description"/>
            <TextBox Grid.Row="3" Text="{Binding Description,Mode=OneWay}" IsReadOnly="{Binding IsNotEditing}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Style="{StaticResource FieldTextBox}"/>

            <Grid Grid.Row="4" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- TODO: dependencies control -->
                <TextBlock Grid.Column="0" Style="{StaticResource HorizontalFieldLabel}" Text="Dependencies"/>
                <TextBlock Grid.Column="1" Text="Placeholder for Dependencies" />
                <Button Grid.Column="2" Content="Delete" Style="{StaticResource DangerButton}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
