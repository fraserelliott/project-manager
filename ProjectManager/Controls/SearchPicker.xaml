<UserControl x:Class="ProjectManager.Controls.SearchPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" mc:Ignorable="d" d:DesignHeight="30"
             d:DesignWidth="300" x:Name="Root">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160" />
            <ColumnDefinition Width="24" />
        </Grid.ColumnDefinitions>

        <TextBox Grid.Column="0" x:Name="SearchBox" Style="{StaticResource FieldTextBoxLeftRounded}"
                 Text="{Binding SearchText, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Width="160" PreviewKeyDown="TextBox_OnPreviewKeyDown" />

        <Button Grid.Column="1" VerticalAlignment="Stretch" Width="24" Click="Button_Click" Padding="2,2"
                FontFamily="Segoe MDL2 Assets" Style="{StaticResource PrimaryButtonRightAttached}" Content="&#xE70D;" />

        <Popup IsOpen="{Binding IsPopupOpen, ElementName=Root}" PlacementTarget="{Binding ElementName=Root}"
               StaysOpen="False" Width="180">
            <Border Background="{StaticResource DropdownBg}" BorderBrush="{StaticResource BrushBorderSubtle}"
                    BorderThickness="1">
                <ListView ItemsSource="{Binding ItemsSource, ElementName=Root}"
                          SelectedItem="{Binding SelectedItem, ElementName=Root}"
                          SelectedIndex="{Binding SelectedIndex, ElementName=Root}"
                          MouseLeftButtonUp="ListView_OnMouseLeftButtonUp" />
            </Border>
        </Popup>
    </Grid>
</UserControl>