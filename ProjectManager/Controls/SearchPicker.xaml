<UserControl x:Class="ProjectManager.Controls.SearchPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" mc:Ignorable="d" d:DesignHeight="30"
             d:DesignWidth="300" x:Name="Root">
    <Grid>
        <TextBox x:Name="SearchBox" Margin="0,0,24,0" Width="160" />

        <Button Width="24" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0"
                Click="Button_Click">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70D;" FontSize="12"
                       PreviewKeyDown="TextBox_OnPreviewKeyDown" />
        </Button>

        <Popup IsOpen="{Binding IsPopupOpen, ElementName=Root}" PlacementTarget="{Binding ElementName=SearchBox}"
               StaysOpen="False">
            <ListView ItemsSource="{Binding ItemsSource, ElementName=Root}"
                      SelectedItem="{Binding SelectedItem, ElementName=Root}"
                      SelectedIndex="{Binding SelectedIndex, ElementName=Root}"
                      MouseLeftButtonUp="ListView_OnMouseLeftButtonUp" />
        </Popup>
    </Grid>
</UserControl>