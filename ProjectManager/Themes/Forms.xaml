<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="VerticalFieldLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style x:Key="HorizontalFieldLabel" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
    </Style>

    <Style x:Key="FieldContainer" TargetType="StackPanel">
        <Setter Property="Margin" Value="6"/>
    </Style>

    <Style x:Key="FieldButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <!-- match FieldContainer spacing -->
        <Setter Property="Margin" Value="6"/>
        <!-- align with other controls under their label -->
        <Setter Property="VerticalAlignment" Value="Bottom"/>
        <Setter Property="MinWidth" Value="90"/>
    </Style>

    <Style x:Key="FieldTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource DropdownBg}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorderSubtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="4">
                        <ScrollViewer x:Name="PART_ContentHost"
                                  Margin="{TemplateBinding Padding}"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsReadOnly" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource BrushFieldReadOnlyBackground}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource BrushBorderSubtle}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FieldTextBoxWithError"
       TargetType="TextBox"
       BasedOn="{StaticResource FieldTextBox}">
        <Style.Triggers>
            <!-- Error but NOT focused -->
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True"/>
                    <Condition Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource Self}}" Value="False"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="BorderBrush" Value="{StaticResource BtnDanger}" />
            </MultiDataTrigger>

            <!-- Error AND focused -->
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True"/>
                    <Condition Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource Self}}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="BorderBrush" Value="{StaticResource FocusedWithError}" />
            </MultiDataTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>